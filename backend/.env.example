# Supabase project URL (found in Supabase Dashboard → Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key — keep this secret, never commit it
# Found in Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Your deployed frontend URL (used to restrict CORS in production)
# Example: https://tourguideai.lovable.app
FRONTEND_URL=https://your-frontend-url.com
